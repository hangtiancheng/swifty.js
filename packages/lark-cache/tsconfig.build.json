{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "./dist",
    "declarationMap": false,
    "inlineSourceMap": false,
    "inlineSources": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "removeComments": true,
    "sourceMap": false
  },
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "src/main.ts"],
  "extends": "./tsconfig.json",
  "include": ["./src/**/*.ts"]
}
