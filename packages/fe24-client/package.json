{
  "name": "@lark.js/fe24-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:webpack",
    "build": "pnpm build:webpack",
    "dev:webpack": "cross-env NODE_OPTIONS=\"--loader ts-node/esm\" webpack serve --mode development --open --config webpack.config.ts",
    "build:webpack": "cross-env NODE_OPTIONS=\"--loader ts-node/esm\" webpack --mode production --config webpack.config.ts",
    "build:esbuild": "cross-env NODE_ENV=production NODE_OPTIONS=\"--loader ts-node/esm\" node ./esbuild.config.ts",
    "dev:rsbuild": "rsbuild dev",
    "build:rsbuild": "rsbuild build",
    "build:rollup": "cross-env NODE_ENV=production NODE_OPTIONS=\"--loader ts-node/esm\" rollup -c rollup.config.ts",
    "build:tsup": "cross-env NODE_ENV=production NODE_OPTIONS=\"--loader ts-node/esm\" tsup --config ./tsup.config.ts",
    "build:all": "cross-env SELECTED_ROUTES=* NODE_OPTIONS=\"--loader ts-node/esm\" webpack --mode production --config ./webpack.config.ts",
    "lint": "eslint . --fix",
    "format": "prettier -w src/ plugins/"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@ant-design/icons": "^6.2.5",
    "@icon-park/react": "^1.4.2",
    "@lark.js/conditional-bundle-plugin": "workspace:*",
    "@lark.js/sentry": "catalog:",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-virtual": "^3.14.3",
    "@types/react": "^18.3.31",
    "animate.css": "^4.1.1",
    "antd": "^6.4.4",
    "axios": "^1.18.0",
    "dotenv": "^17.4.2",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.6",
    "express": "^4.22.2",
    "postcss": "^8.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.3.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^10.5.0",
    "@inquirer/prompts": "^8.5.2",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rollup/plugin-url": "^8.0.2",
    "@rsbuild/core": "^1.7.5",
    "@rsbuild/plugin-react": "^1.4.6",
    "@rsbuild/plugin-sass": "^1.5.3",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@types/webpack-env": "^1.18.8",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "dotenv-webpack": "^9.0.0",
    "esbuild": "^0.27.7",
    "esbuild-postcss-plugin": "^0.0.7",
    "esbuild-sass-plugin": "^3.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "html-webpack-plugin": "^5.6.7",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss-loader": "^8.2.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rollup": "^4.62.0",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.101.0",
    "sass-loader": "^16.0.8",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.107.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5"
  }
}
