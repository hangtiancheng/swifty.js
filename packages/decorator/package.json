{
  "name": "@swifty.js/decorator",
  "version": "0.0.1",
  "description": "Lightweight dependency injection container for JavaScript/TypeScript",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf ./dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "format": "prettier -w ./",
    "format:check": "prettier --check ./"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hangtiancheng/swifty.js.git",
    "directory": "packages/decorator"
  },
  "keywords": [
    "dependency injection",
    "dependency",
    "injection",
    "ioc",
    "container",
    "javascript",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">= 20"
  },
  "author": "https://github.com/hangtiancheng",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hangtiancheng/swifty.js#issue"
  },
  "homepage": "https://github.com/hangtiancheng/swifty.js#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.46",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.10"
  }
}
