{
  "name": "lark-index",
  "version": "0.0.1",
  "description": "Chrome homepage",
  "keywords": [
    "@lark.js/mvc",
    "homepage",
    "tailwindcss"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier -w ./",
    "typecheck": "tsc --noEmit",
    "pwa": "pnpm dlx @vite-pwa/assets-generator --preset minimal public/favicon.svg -y"
  },
  "dependencies": {
    "@lark.js/mvc": "workspace:*",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.13.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "packageManager": "pnpm@10.33.0"
}
