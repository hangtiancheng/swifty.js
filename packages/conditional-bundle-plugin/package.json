{
  "name": "@lark.js/conditional-bundle-plugin",
  "version": "1.0.0",
  "description": "",
  "main": "dist/core/index.cjs",
  "module": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs",
      "types": "./dist/core/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite/index.js",
      "require": "./dist/vite/index.cjs",
      "types": "./dist/vite/index.d.ts"
    },
    "./rollup": {
      "import": "./dist/rollup/index.js",
      "require": "./dist/rollup/index.cjs",
      "types": "./dist/rollup/index.d.ts"
    },
    "./esbuild": {
      "import": "./dist/esbuild/index.js",
      "require": "./dist/esbuild/index.cjs",
      "types": "./dist/esbuild/index.d.ts"
    },
    "./rsbuild": {
      "import": "./dist/rsbuild/index.js",
      "require": "./dist/rsbuild/index.cjs",
      "types": "./dist/rsbuild/index.d.ts"
    },
    "./webpack": {
      "import": "./dist/webpack/index.js",
      "require": "./dist/webpack/index.cjs",
      "types": "./dist/webpack/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:tsup": "tsup --config ./tsup.config.ts",
    "dev": "rollup -c rollup.config.js -w",
    "format": "prettier -w ./"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "magic-string": "^0.30.21",
    "picomatch": "^4.0.4"
  },
  "peerDependencies": {
    "@rsbuild/core": ">=1.0.0",
    "esbuild": ">=0.27.0",
    "rollup": ">=4.0.0",
    "vite": ">=5.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "type": "module",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "@rsbuild/core": "^1.7.5",
    "@types/node": "catalog:",
    "@types/picomatch": "^4.0.3",
    "@types/webpack": "^5.28.5",
    "esbuild": "^0.27.7",
    "prettier": "^3.8.4",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.0"
  }
}
