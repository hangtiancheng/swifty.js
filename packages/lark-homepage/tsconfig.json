{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "paths": {
      "@/*": ["./src/*"],
      "@lark-docs/generated/*": ["./.lark-docs/generated/*"]
    }
  },
  "include": ["**/*.ts"]
}
