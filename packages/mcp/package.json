{
  "name": "@lark.js/mcp",
  "version": "1.0.0",
  "description": "MCP server for prompts using fastify and mongodb",
  "main": "dist/index.js",
  "scripts": {
    "start": "pnpm build && node dist/index.js",
    "benchmark": "tsx scripts/benchmark.ts",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx src/index.ts",
    "dev:client": "cd src/client && rollup -c -w",
    "build": "concurrently \"pnpm build:server\" \"pnpm build:client\"",
    "build:server": "tsc",
    "build:client": "cd src/client && rollup -c",
    "build:tsup": "concurrently \"pnpm build:server\" \"pnpm build:tsup:client\"",
    "build:tsup:client": "cd src/client && tsup --config ./tsup.config.ts",
    "format": "prettier -w ./"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@koa/bodyparser": "^6.1.0",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.6.0",
    "@langchain/core": "^1.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "i18next": "^25.10.10",
    "koa": "^3.2.1",
    "koa-static": "^5.0.0",
    "lucide-react": "^0.577.0",
    "mongodb": "^7.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^16.6.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/autocannon": "^7.12.7",
    "@types/jsdom": "^28.0.3",
    "@types/koa": "^3.0.3",
    "@types/koa-static": "^4.0.4",
    "@types/koa__cors": "^5.0.1",
    "@types/koa__router": "^12.0.5",
    "@types/node": "catalog:",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autocannon": "^7.15.0",
    "autoprefixer": "^10.5.1",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.23",
    "esbuild": "^0.27.7",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "rollup": "^4.62.2",
    "rollup-plugin-postcss": "^4.0.2",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "type": "module"
}
