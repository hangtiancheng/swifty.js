{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "esnext",
    "lib": ["esnext", "dom"],
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "jsxImportSource": "@swifty.js/preact",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["./src/**/*", "./tsup.config.ts"]
}
