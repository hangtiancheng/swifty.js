{
  "name": "@swifty.js/preact",
  "version": "0.0.3",
  "description": "Preact all in one",
  "keywords": [
    "all-in-one",
    "fork",
    "framework",
    "jsx",
    "light-weight",
    "preact",
    "react",
    "virtual-dom"
  ],
  "homepage": "https://github.com/hangtiancheng/swifty.js/tree/main/packages/preact#readme",
  "bugs": {
    "url": "https://github.com/hangtiancheng/swifty.js/issues"
  },
  "license": "MIT",
  "author": "hangtiancheng",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hangtiancheng/swifty.js.git",
    "directory": "packages/preact"
  },
  "files": [
    "src/**/*.d.ts",
    "dist",
    "mangle.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/preact.mjs",
  "module": "dist/preact.mjs",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/preact.mjs"
    },
    "./hooks": {
      "types": "./src/hooks/index.d.ts",
      "import": "./dist/hooks.mjs"
    },
    "./compat": {
      "types": "./src/compat/internal/index.d.ts",
      "import": "./dist/compat.mjs"
    },
    "./compat/client": {
      "types": "./src/compat/client.d.ts",
      "import": "./dist/client.mjs"
    },
    "./compat/scheduler": {
      "import": "./dist/scheduler.mjs"
    },
    "./jsx-runtime": {
      "types": "./src/jsx-runtime/index.d.ts",
      "import": "./dist/jsx-runtime.mjs"
    },
    "./jsx-dev-runtime": {
      "types": "./src/jsx-runtime/index.d.ts",
      "import": "./dist/jsx-runtime.mjs"
    },
    "./compat/jsx-runtime": {
      "types": "./src/jsx-runtime/index.d.ts",
      "import": "./dist/compat-jsx-runtime.mjs"
    },
    "./compat/jsx-dev-runtime": {
      "types": "./src/jsx-runtime/index.d.ts",
      "import": "./dist/compat-jsx-dev-runtime.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "format": "prettier -w .",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "rollup-plugin-esbuild": "^6.2.1"
  },
  "packageManager": "pnpm@10.10.0"
}
