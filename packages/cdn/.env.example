# Swifty CDN Server Configuration
# Copy this file to .env and modify as needed.

# Server port (default: 3300)
CDN_PORT=3300

# MongoDB connection URI (default: mongodb://localhost:27017/cdn)
CDN_MONGO_URI=mongodb://localhost:27017/cdn

# L1 cache max size in bytes (default: 134217728 = 128 MB)
# CDN_CACHE_MAX_SIZE=134217728

# L1 cache max entry size in bytes (default: 2097152 = 2 MB)
# CDN_CACHE_MAX_ENTRY_SIZE=2097152

# CDN route prefix (default: /cdn)
# CDN_PREFIX=/cdn

# API route prefix (default: /api)
# CDN_API_PREFIX=/api

# Grayscale header name (default: x-use-gray)
# CDN_GRAYSCALE_HEADER=x-use-gray

# Grayscale cookie prefix (default: cdn_gray_)
# CDN_GRAYSCALE_COOKIE_PREFIX=cdn_gray_

# Workspace root directory for auto-discovering dist directories (default: process.cwd())
# Set this to your monorepo root so the discover API can find child project dists.
CDN_WORKSPACE_ROOT="../"
