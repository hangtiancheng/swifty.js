{
  "author": "https://github.com/hangtiancheng",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.7",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {},
  "name": "lark",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hangtiancheng/lark.git"
  },
  "scripts": {
    "build:lark": "pnpm --filter @lark.js/mvc build",
    "dev:lark": "pnpm build:lark && concurrently \"pnpm dev:lark-cdn\" \"pnpm dev:lark-demo\" \"pnpm dev:lark-devtool\"",
    "dev:lark-cdn": "CDN_WORKSPACE_ROOT=.. pnpm --filter @lark.js/cdn dev",
    "dev:lark-demo": "pnpm --filter lark-demo dev:webpack",
    "dev:lark-devtool": "pnpm --filter @lark.js/devtool dev",
    "prepare": "husky",
    "preview": "vitepress preview",
    "test": "concurrently \"pnpm test:bloom-filter\" \"pnpm test:distributed-lock\" \"pnpm test:math\" \"pnpm test:mini-zustand\" \"pnpm test:react-vue\" \"pnpm test:vue-reactivity\"",
    "test:bloom-filter": "pnpm --filter @lark.js/bloom-filter test",
    "test:distributed-lock": "pnpm --filter @lark.js/distributed-lock test",
    "test:math": "pnpm --filter @lark.js/math test",
    "test:mini-zustand": "pnpm --filter @lark.js/mini-zustand test",
    "test:vue-reactivity": "pnpm --filter @lark.js/vue-reactivity test",
    "git:precommit": "rm -rf ./.claude && ln -s ./.github ./.claude",
    "git:commit": "pnpm git:precommit && git add -A && git commit -m \"feat: Introduce new features\"",
    "git:push": "pnpm git:commit && git push origin main"
  },
  "type": "module"
}
